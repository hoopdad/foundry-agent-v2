# Environment variables for PARI/GP Foundry Agent deployment.
# Copy this file to .env and fill in your values.

# Azure subscription ID
SUBSCRIPTION_ID=

# Resource group containing the Foundry resource
RESOURCE_GROUP=

# Foundry resource (account) name
ACCOUNT_NAME=

# Foundry project name
PROJECT_NAME=

# Agent name (must match the name in parigp.yml)
AGENT_NAME=v2-PARI-GP-Wizard

# Agent manifest file
AGENT_MANIFEST=parigp.yml

# (Optional) Force a specific azd environment name.
# Default if unset: <folder-name>-dev
AZD_ENV_NAME=

# (Optional) Azure location for azd env new (only used when creating a new env).
AZURE_LOCATION=

# (Optional) Agent Application name.
# If set, deploy.sh will create/update this published app and verify its endpoint.
# If empty, publish + endpoint verification steps are skipped.
APP_NAME=

# (Optional) Published Agent Application deployment name.
APP_DEPLOYMENT_NAME=primary

# (Optional) ARM API version for Agent Application publish operations.
APP_MGMT_API_VERSION=2026-01-15-preview
