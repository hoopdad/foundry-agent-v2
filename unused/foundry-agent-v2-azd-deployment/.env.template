# Environment variables for PARI/GP Foundry Agent deployment.
# Copy this file to .env and fill in your values.

# ── Required ─────────────────────────────────────────────────────────────────

# Azure subscription ID
SUBSCRIPTION_ID=

# Resource group containing the Foundry resource
RESOURCE_GROUP=

# Foundry resource (account) name
ACCOUNT_NAME=

# Foundry project name
# Default: <ACCOUNT_NAME>-project. Created automatically if it doesn't exist.
PROJECT_NAME=

# Agent name (must match the name in parigp.yml)
AGENT_NAME=v2-PARI-GP-Wizard

# Agent manifest file (relative to this directory)
AGENT_MANIFEST=parigp.yml

# ── Optional ─────────────────────────────────────────────────────────────────

# Model deployment name. Default: DeepSeek-V3.2
# The model is created automatically if no deployment with this name exists.
MODEL_NAME=

# Model SKU. Default: Standard
MODEL_SKU=

# Model capacity (TPM). Default: 1
MODEL_CAPACITY=

# Force a specific azd environment name.  Default: <folder-name>-dev
AZD_ENV_NAME=

# Azure location for first-time azd env creation (e.g. eastus2).
AZURE_LOCATION=

# Agent Application name. If set, deploy.sh will publish the app and verify
# its endpoint. If empty, those steps are skipped.
APP_NAME=

# Published Agent Application deployment name. Default: primary
APP_DEPLOYMENT_NAME=primary

# ARM API version for Agent Application publish operations.
APP_MGMT_API_VERSION=2026-01-15-preview

# ── MCP (Optional — all three auto-resolve if left blank) ───────────────────
# deploy.sh resolves MCP automatically in this order:
#   1. MCP_SERVER_URL: from this file > inferred from ../mcp/.env APP_NAME
#   2. MCP_PROJECT_CONNECTION_ID: from this file > looked up by MCP_CONNECTION_NAME
#      > auto-discovered (any project connection whose target ends with /mcp)
#      > auto-created via ARM API using MCP_SERVER_URL
#
# You only need to set these if the auto-resolution doesn't apply to your setup.

# Connection name for IaC provisioning. If set with MCP_SERVER_URL, deploy.sh
# tells azd to provision the connection via Bicep before azd up.
MCP_CONNECTION_NAME=

# Full URL of the MCP server (e.g. https://myapp.azurewebsites.net/mcp).
# Auto-inferred from ../mcp/.env APP_NAME when left blank.
MCP_SERVER_URL=

# Override with a pre-existing connection id. Skips all MCP resolution.
MCP_PROJECT_CONNECTION_ID=
